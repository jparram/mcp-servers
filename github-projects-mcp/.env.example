# Copy to .env and fill in your values
# Never commit .env to VCS

# Required: GitHub PAT with these scopes:
#   - repo (for issues, milestones, labels)
#   - project (for Projects v2 read/write)
#   - read:org (for org project listing)
GITHUB_TOKEN=ghp_your_token_here

# HTTP transport only (optional, default: 3000)
PORT=3000
