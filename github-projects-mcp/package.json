{
  "name": "github-projects-mcp",
  "version": "1.0.0",
  "description": "MCP server for GitHub Projects v2 via GraphQL",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "github-projects-mcp": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "graphql-request": "^7.1.2",
    "graphql": "^16.10.0",
    "zod": "^3.24.2",
    "express": "^4.21.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
